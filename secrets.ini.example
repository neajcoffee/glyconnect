; Template pour les nouveaux dev.
; Copier ce fichier en `secrets.ini` (à la racine du projet) puis remplir avec
; tes vraies valeurs. `secrets.ini` est git-ignoré et ne doit PAS être commité.

[secrets]
; Réseau WiFi auquel le TC001 se connecte (modes ble_dev, wifi_prod...)
wifi_ssid          = YourWiFiName
wifi_pass          = YourWiFiPassword

; ID Dexcom G6 — chaîne de 6 caractères imprimée sur le transmetteur
transmitter_id     = ABCDEF

; Topics ntfy.sh — choisir des chaînes random ~16+ chars (ntfy = pas d'auth,
; quiconque connaît le topic peut lire/écrire). Voir https://docs.ntfy.sh/publish/
ntfy_log_topic     = your-app-log-xxxxxx
ntfy_ota_topic     = your-app-ota-xxxxxx
ntfy_data_topic    = your-app-data-xxxxxx

; URL de base pour les Releases GitHub (production OTA)
ota_base_url       = https://github.com/yourname/yourrepo/releases/latest/download

; Nightscout (mode wifi_prod uniquement)
nightscout_url     = https://your-nightscout.example.com
nightscout_api_key =
